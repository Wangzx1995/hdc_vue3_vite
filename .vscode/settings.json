{
    "editor.tabSize": 4,
    "workbench.colorCustomizations": {},
    "editor.detectIndentation": false,
    "eslint.codeAction.disableRuleComment": {
        "enable": false
    },
    "eslint.codeAction.showDocumentation": {
        "enable": false
    },
    "editor.fontLigatures": null,
    "eslint.probe": [
        "javascriptreact",
        "typescript",
        "typescriptreact",
        "html",
        "vue",
        "markdown"
    ],
    "workbench.editorAssociations": {},
    "i18n-ally.localesPaths": [
        "src/i18n",
        "src/i18n/langs",
        "src/components/hui-pro/locale",
        "src/components/hui-pro/locale/lang",
        "src/components/hui-pro/plan/lang"
    ]
}
